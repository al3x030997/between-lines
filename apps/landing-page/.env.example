# Site
# Pin to the production URL across all Vercel envs so preview deploys still
# emit working magic links. In local dev, override in .env.local to http://localhost:3000.
NEXT_PUBLIC_SITE_URL=https://between-reads-kohl.vercel.app

# Database — auto-injected by the Vercel-Neon integration.
# DATABASE_URL is the pooled connection (use at runtime).
# DATABASE_URL_UNPOOLED is the direct connection (use for migrations).
# Older Vercel Postgres var names (POSTGRES_URL / POSTGRES_URL_NON_POOLING)
# are also accepted as fallbacks.
DATABASE_URL=postgres://...
DATABASE_URL_UNPOOLED=postgres://...

# Upstash Redis — auto-injected by the Vercel Upstash KV integration.
KV_REST_API_URL=https://...
KV_REST_API_TOKEN=...

# Kit (ConvertKit)
KIT_API_KEY=kit_...
KIT_FORM_ID=1234567
KIT_WEBHOOK_SECRET=...

# App secrets — generate with `openssl rand -base64 32`.
# Rotating COOKIE_JWT_SECRET invalidates all insider sessions.
MAGIC_LINK_SECRET=...
COOKIE_JWT_SECRET=...
