# Shared monorepo env. Per-app .env files live in apps/<app>/.env

# === Database (shared) ===
DATABASE_URL=postgresql://autoquery:autoquery@db:5432/autoquery

# === Redis (shared) ===
REDIS_URL=redis://redis:6379/0

# === Ollama (shared) ===
OLLAMA_URL=http://ollama:11434

# === Auth ===
SECRET_KEY=change-me-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# === Matching weights (agent-match only) ===
GENRE_SCORE_WEIGHT=0.35
FTS_SCORE_WEIGHT=0.25
SEMANTIC_SCORE_WEIGHT=0.25
AUDIENCE_SCORE_WEIGHT=0.15

# === Models ===
EMBEDDING_MODEL=nomic-embed-text
EXTRACTOR_MODEL=llama3.1:8b

# === Anthropic (page classifier) ===
ANTHROPIC_API_KEY=sk-ant-...
CLASSIFIER_BACKEND=claude
CLASSIFIER_CLAUDE_MODEL=claude-haiku-4-5-20251001
